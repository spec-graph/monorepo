    "ws": "^8.16.0",
    "chokidar": "^3.6.0",
    "execa": "^8.0.0",
    "js-yaml": "^4.1.0",
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/ws": "^8.5.0",

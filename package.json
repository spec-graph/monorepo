{
  "name": "spec-graph-monorepo",
  "version": "2.0.0",
  "private": true,
  "description": "spec-graph v2: strict-gate, prompt-driven, automatic progression development brain. Monorepo with core (engine), cli (human/agent interface), and skills (SKILL.md collection for AI agents).",
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/skills"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:core": "npm run dev --workspace=packages/core",
    "dev:cli": "npm run dev --workspace=packages/cli",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present"
  },
  "keywords": [
    "specification",
    "workflow",
    "orchestration",
    "ai-agent",
    "automation",
    "quality-gates",
    "claude-code",
    "codex"
  ],
  "author": "spec-graph team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spec-graph/spec-graph.git"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgres://flashsale:flashsale@localhost:5432/flashsale
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=flash-sale:
REDIS_MODE=single

# RabbitMQ
RABBITMQ_URL=amqp://flashsale:flashsale@localhost:5672
RABBITMQ_EXCHANGE=flash-sale
RABBITMQ_PREFETCH=50

# JWT
JWT_SECRET=your-jwt-secret-change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_MS=604800000

# Bcrypt
BCRYPT_COST=12

# Rate Limit
RATE_LIMIT_USER_MAX=30
RATE_LIMIT_USER_REFILL=10
RATE_LIMIT_IP_MAX=60
RATE_LIMIT_IP_REFILL=20
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_REFILL=1

# Order
ORDER_PAYMENT_TIMEOUT_MS=900000
ORDER_AUTO_CANCEL_INTERVAL_MS=60000

# Inventory
INVENTORY_RESERVATION_TTL_SEC=300
INVENTORY_SYNC_INTERVAL_MS=30000

# Queue
QUEUE_ENTRY_TIMEOUT_MS=600000
QUEUE_CLEANUP_INTERVAL_MS=30000
QUEUE_AVG_PROCESSING_MS=100
QUEUE_WORKER_INTERVAL_MS=200

# Security
HMAC_SECRET=your-hmac-secret-change-me-in-production
TIMESTAMP_WINDOW_MS=300000
NONCE_TTL_SECONDS=300
IDEMPOTENCY_TTL_SECONDS=86400
MAX_BODY_SIZE=1048576
MAX_STRING_LENGTH=10000

# Payment
PAYMENT_SUCCESS_RATE=0.95
PAYMENT_LATENCY_MS=200

# Sale
SALE_WARMUP_ADVANCE_MS=60000
SALE_WARMUP_RETRY_MS=5000
SALE_AUTO_TRANSITION_MS=1000

# Shutdown
SHUTDOWN_DRAIN_TIMEOUT_MS=30000
